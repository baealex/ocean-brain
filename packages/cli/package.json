{
    "name": "ocean-brain",
    "version": "0.8.1",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/baealex/ocean-brain"
    },
    "homepage": "https://github.com/baealex/ocean-brain",
    "bugs": {
        "url": "https://github.com/baealex/ocean-brain/issues"
    },
    "bin": {
        "ocean-brain": "dist/index.js"
    },
    "files": [
        "dist",
        "scripts/postinstall-prisma.mjs",
        "server/dist",
        "server/prisma/schema.prisma",
        "server/prisma/migrations",
        "server/client/dist"
    ],
    "scripts": {
        "dev": "tsx src/index.ts",
        "build": "tsup",
        "postinstall": "node ./scripts/postinstall-prisma.mjs",
        "test": "tsx --test test/**/*.test.ts",
        "test:ci": "tsx --test test/**/*.test.ts",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@baejino/auth": "catalog:",
        "@blocknote/core": "catalog:",
        "@graphql-tools/schema": "catalog:",
        "@graphql-tools/utils": "catalog:",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@prisma/client": "catalog:",
        "commander": "^14.0.3",
        "diff": "catalog:",
        "express": "catalog:",
        "express-rate-limit": "catalog:",
        "express-session": "catalog:",
        "express-winston": "catalog:",
        "graphql-http": "catalog:",
        "jsdom": "catalog:",
        "lusca": "catalog:",
        "prisma": "catalog:",
        "sqlite3": "catalog:",
        "winston": "catalog:",
        "zod": "^3.25.76"
    },
    "oceanBrain": {
        "mcpCompatibilityVersion": "0.8.0"
    }
}
