{
    "name": "@ocean-brain/server",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "main": "dist/main.js",
    "scripts": {
        "dev": "prisma migrate deploy && prisma generate && node --watch --import tsx src/main.ts",
        "build": "prisma generate && tsup && tsc-alias",
        "start": "node dist/start.js",
        "lint": "biome check .",
        "format": "biome check --write .",
        "test": "tsx --tsconfig tsconfig.json --test src/**/*.test.ts test/**/*.test.ts",
        "test:ci": "tsx --tsconfig tsconfig.json --test src/**/*.test.ts test/**/*.test.ts",
        "type-check": "tsc --noEmit"
    },
    "dependencies": {
        "@baejino/auth": "catalog:",
        "@blocknote/server-util": "catalog:",
        "@graphql-tools/schema": "catalog:",
        "@graphql-tools/utils": "catalog:",
        "@prisma/client": "catalog:",
        "diff": "catalog:",
        "express": "catalog:",
        "express-rate-limit": "catalog:",
        "express-session": "catalog:",
        "express-winston": "catalog:",
        "graphql-http": "catalog:",
        "lusca": "catalog:",
        "prisma": "catalog:",
        "sqlite3": "catalog:",
        "winston": "catalog:"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.11",
        "@types/express": "^5.0.6",
        "@types/express-session": "^1.18.2",
        "glob": "^13.0.6",
        "tsc-alias": "^1.8.16",
        "tsup": "^8.5.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
